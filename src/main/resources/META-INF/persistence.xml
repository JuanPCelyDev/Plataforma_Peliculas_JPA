<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="plataformaPelisUnit" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!--Clases-->
        <class>org.cursoPlatzi.entity.Pelicula</class>
        <class>org.cursoPlatzi.entity.Director</class>
        <class>org.cursoPlatzi.entity.Categoria</class>

        <!-- Propiedades de conexión -->
        <properties >
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/plataforma_peliculas"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="Canela2026$"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <!--crear las tablas si no existen y las actualiza si agregas campos -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Ver qué está haciendo Hibernate en tu consola -->
<!--            <property name="hibernate.show_sql" value="true"/>-->
<!--            <property name="hibernate.format_sql" value="true"/>-->

            <!-- Dialecto para MySQL 8 o superior -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
        </properties>

    </persistence-unit>

</persistence>